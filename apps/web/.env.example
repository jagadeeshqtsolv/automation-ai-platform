DATABASE_URL="file:./dev.db"

# Required: min 32 characters — signs session tokens and encrypts stored secrets (API keys, git tokens)
# Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-random-string-at-least-32-characters-long"

# Optional: absolute path to per-project framework folders (default: <repo>/frameworks)
# FRAMEWORKS_ROOT=

# Optional: absolute path to packages/core/web (default: auto-detected from CWD)
# WEB_CORE_ROOT=

# Required: GitHub PAT with read:packages scope — used by npm install to pull
# @jagadeeshqtsolv packages from GitHub Package Registry when running tests locally.
# Create at: github.com → Settings → Developer settings → Personal access tokens (classic)
# Scope needed: read:packages
NODE_AUTH_TOKEN="ghp_your_read_packages_token_here"

# Note: AI provider API keys (OpenAI, Claude) are configured per-project in the UI
# under Project → Setup → AI. No server-level key is needed.
