# ── Required ──────────────────────────────────────────────────────────────────

# Session signing + API key encryption key (AES-256-GCM).
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-string

# GitHub Personal Access Token with read:packages scope.
# Needed at build time to install @jagadeeshqtsolv/core from GitHub Packages.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the container listens on (default: 3000)
# PORT=3000
