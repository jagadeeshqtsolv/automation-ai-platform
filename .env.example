# Copy this to .env and fill in values before running docker-compose up

# Required: random string, at least 32 characters (used to sign session cookies)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters-long

# Optional: server-level fallback OpenAI key (customers can also set per-project keys in the UI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Optional: expose on a different host port (default 3000)
PORT=3000
